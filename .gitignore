# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Excel lock files
~$*.xlsx
~$*.xlsm

# Local scratch / temp output (use working_files/ for things you want versioned)
tmp/
scratch/
*.tmp

# Untracked working CSVs (snapshots ARE tracked; ad-hoc pulls are not)
data/*_working.csv
data/test.csv
